# Production env — used when running `next build` / `npm run deploy`.
# Copy to .env.production and set your real values. Do not commit .env.production.
#
# Required for Cloudflare Workers deploy (client bundle is built with these inlined):
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxx
NEXT_PUBLIC_APP_URL=https://subcompliant.skypathwayz.workers.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
