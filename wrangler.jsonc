{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "subcompliant",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "subcompliant"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  // Public env vars baked into the Worker at deploy time (not secrets).
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://subcompliant.skypathwayz.workers.dev"
  },
  // Emit structured logs visible in `wrangler tail` and the CF dashboard.
  // head_sampling_rate: 1 = capture every request (reduce in high-traffic prod).
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  // "limits": { "cpu_ms": 30000 }  -- paid plans only; uncomment after upgrading
}
